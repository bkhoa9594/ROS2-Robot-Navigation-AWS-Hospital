<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode name="NavigateRecovery" number_of_retries="6">
      
      <PipelineSequence name="NavigateWithReplanning">
        <RateController hz="1.0">
          <RecoveryNode name="ComputePathToPose" number_of_retries="1">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased" error_code_id="{compute_path_error_code}"/>
            <ClearEntireCostmap name="ClearGlobalCostmap-Context" service_name="global_costmap/clear_entirely_global_costmap"/>
          </RecoveryNode>
        </RateController>

        <RecoveryNode name="FollowPath_Recovery" number_of_retries="1">
          <FollowPath path="{path}" controller_id="FollowPath" error_code_id="{follow_path_error_code}"/>
          <ClearEntireCostmap name="ClearLocalCostmap-Context" service_name="local_costmap/clear_entirely_local_costmap"/>
        </RecoveryNode>
      </PipelineSequence>

      <RoundRobin name="RecoveryActions">
        <ClearEntireCostmap name="ClearLocalCostmap-Subtree" service_name="local_costmap/clear_entirely_local_costmap"/>
        
        <Wait wait_duration="2.0"/>

        <Sequence name="EvadeObstacleLogic">
          <BackUp backup_dist="-0.3" backup_speed="0.15"/>
          
          <RetryUntilSuccessful num_attempts="12">
            <Sequence name="SpinAndCheck">
              <Spin spin_dist="0.52"/> <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
            </Sequence>
          </RetryUntilSuccessful>
        </Sequence>
      </RoundRobin>

    </RecoveryNode>
  </BehaviorTree>

  <TreeNodesModel>
    <Action ID="BackUp" editable="true">
      <input_port name="backup_dist"/>
      <input_port name="backup_speed"/>
    </Action>
    <Action ID="ClearEntireCostmap" editable="true">
      <input_port name="service_name"/>
    </Action>
    <Action ID="ComputePathToPose" editable="true">
      <input_port name="goal"/>
      <input_port name="path"/>
      <input_port name="planner_id"/>
      <input_port name="error_code_id"/>
    </Action>
    <Action ID="FollowPath" editable="true">
      <input_port name="path"/>
      <input_port name="controller_id"/>
      <input_port name="error_code_id"/>
    </Action>
    <Action ID="Spin" editable="true">
      <input_port name="spin_dist"/>
    </Action>
    <Action ID="Wait" editable="true">
      <input_port name="wait_duration"/>
    </Action>
    <Control ID="PipelineSequence" editable="true"/>
    <Control ID="RecoveryNode" editable="true">
      <input_port name="number_of_retries"/>
    </Control>
    <Control ID="RoundRobin" editable="true"/>
    <Control ID="Sequence" editable="true"/>
    <Control ID="RetryUntilSuccessful" editable="true">
      <input_port name="num_attempts"/>
    </Control>
    <Decorator ID="RateController" editable="true">
      <input_port name="hz"/>
    </Decorator>
  </TreeNodesModel>
</root>